{
  "type": "APL",
  "version": "1.8",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "paddingLeft": "24dp",
        "paddingRight": "24dp",
        "paddingTop": "20dp",
        "paddingBottom": "20dp",
        "items": [
          {
            "type": "Text",
            "text": "Escala MOPS - ${payload.dateLabel}",
            "style": "textStylePrimary1"
          },
          {
            "type": "Sequence",
            "width": "100%",
            "height": "100%",
            "scrollDirection": "horizontal",
            "data": "${payload.sections}",
            "items": [
              {
                "type": "Frame",
                "width": "31vw",
                "marginRight": "16dp",
                "padding": "12dp",
                "borderColor": "#3f3f46",
                "borderWidth": "1dp",
                "backgroundColor": "#18181b",
                "items": [
                  {
                    "type": "Text",
                    "text": "${data.title}",
                    "style": "textStylePrimary2"
                  },
                  {
                    "type": "Sequence",
                    "height": "78vh",
                    "data": "${data.items}",
                    "items": [
                      {
                        "type": "Text",
                        "text": "${data}",
                        "style": "textStylePrimary3",
                        "maxLines": 1
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}

