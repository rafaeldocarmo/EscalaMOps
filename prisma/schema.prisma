// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js + campos extras (phone para celular, password para login email/senha)
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // hash para login com email/senha
  phone         String?   // celular obrigatório após login
  role          UserRole  @default(USER)

  accounts Account[]
  sessions Session[]

  @@map("users")
}

enum Level {
  N1
  N2
  ESPC
  PRODUCAO
}

enum Shift {
  T1
  T2
  T3
  TC
}

model TeamMember {
  id                    String   @id @default(cuid())
  name                  String
  phone                 String
  normalizedPhone       String   @map("normalized_phone")
  level                 Level
  shift                 Shift
  sobreaviso            Boolean  @default(false)
  participatesInSchedule Boolean @default(true) @map("participates_in_schedule")
  rotationIndex         Int      @default(0) @map("rotation_index")
  onCallRotationIndex   Int      @default(0) @map("on_call_rotation_index")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  scheduleAssignments     ScheduleAssignment[]
  swapRequestsAsRequester ScheduleSwapRequest[] @relation("SwapRequester")
  swapRequestsAsTarget    ScheduleSwapRequest[] @relation("SwapTarget")
  onCallAssignments       OnCallAssignment[]

  bankHourBalance       BankHourBalance? @relation("BankHourBalance")
  bankHourRequests      BankHourRequest[] @relation("BankHourRequests")
  bankHourTransactions   BankHourTransaction[] @relation("BankHourTransactions")

  @@index([normalizedPhone])
  @@map("team_members")
}

enum ScheduleStatus {
  OPEN
  LOCKED
}

enum AssignmentStatus {
  WORK
  OFF
  SWAP_REQUESTED
}

model Schedule {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  status    ScheduleStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ScheduleAssignment[]

  @@unique([year, month])
  @@map("schedules")
}

model ScheduleAssignment {
  id         String           @id @default(cuid())
  scheduleId String           @map("schedule_id")
  memberId   String           @map("member_id")
  date       DateTime
  status     AssignmentStatus

  schedule Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  member   TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, memberId, date])
  @@map("schedule_assignments")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum SwapType {
  OFF_SWAP
  QUEUE_SWAP
  ONCALL_SWAP
  SHIFT_SWAP
}

enum SwapRequestStatus {
  PENDING
  WAITING_SECOND_USER
  SECOND_USER_ACCEPTED
  APPROVED
  REJECTED
  CANCELLED
}

model ScheduleSwapRequest {
  id                   String            @id @default(cuid())
  type                 SwapType
  requesterId          String            @map("requester_id")
  targetMemberId       String?           @map("target_member_id")
  originalDate         DateTime?         @map("original_date")
  targetDate           DateTime?         @map("target_date")
  justification        String?           @map("justification")
  status               SwapRequestStatus
  secondUserAcceptedAt DateTime?        @map("second_user_accepted_at")
  adminApprovedAt      DateTime?         @map("admin_approved_at")
  adminRejectedAt      DateTime?         @map("admin_rejected_at")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  requester   TeamMember @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetMember TeamMember? @relation("SwapTarget", fields: [targetMemberId], references: [id], onDelete: SetNull)

  @@map("schedule_swap_requests")
}

model OnCallAssignment {
  id        String   @id @default(cuid())
  memberId  String   @map("member_id")
  level     Level
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")

  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("on_call_assignments")
}

enum BankHourRequestType {
  EXTRA_HOURS
  OFF_HOURS
}

enum BankHourRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model BankHourBalance {
  memberId     String   @id @map("member_id")
  balanceHours Decimal  @default(0) @map("balance_hours") @db.Decimal(10, 2)
  updatedAt    DateTime @updatedAt @map("updated_at")

  member TeamMember @relation("BankHourBalance", fields: [memberId], references: [id], onDelete: Cascade)

  @@map("bank_hour_balances")
}

model BankHourRequest {
  id             String                  @id @default(cuid())
  type           BankHourRequestType
  requesterId    String                  @map("requester_id")
  date           DateTime                @map("date")
  hours          Decimal                 @map("hours") @db.Decimal(10, 2)
  justification  String?                 @map("justification")
  status         BankHourRequestStatus
  adminApprovedAt DateTime?             @map("admin_approved_at")
  adminRejectedAt DateTime?             @map("admin_rejected_at")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  requester TeamMember @relation("BankHourRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  transaction BankHourTransaction?

  @@index([requesterId, status])

  @@map("bank_hour_requests")
}

model BankHourTransaction {
  id          String            @id @default(cuid())
  memberId    String            @map("member_id")
  requestId   String            @unique @map("request_id")
  deltaHours  Decimal           @map("delta_hours") @db.Decimal(10, 2)
  createdAt   DateTime          @default(now()) @map("created_at")

  member   TeamMember     @relation("BankHourTransactions", fields: [memberId], references: [id], onDelete: Cascade)
  request  BankHourRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("bank_hour_transactions")
}
