// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js + campos extras (phone para celular, password para login email/senha)
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  USER
  ADMIN
  ADMIN_TEAM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // hash para login com email/senha
  phone         String?   // celular obrigatório após login
  role          UserRole  @default(USER)
  /** When role is ADMIN_TEAM, the only team this user may see and manage. */
  managedTeamId String?   @map("managed_team_id")
  /**
   * Definido apenas no banco (seed/SQL). No máximo um usuário com true.
   * Não pode ser alterado pela tela de permissões nem por updateUserRole.
   */
  isGlobalAdmin Boolean @default(false) @map("is_global_admin")

  accounts Account[]
  sessions Session[]

  managedTeam Team? @relation("UserManagedTeam", fields: [managedTeamId], references: [id], onDelete: SetNull)

  @@map("users")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           TeamMember[]
  schedules         Schedule[]
  usersManagingTeam User[]       @relation("UserManagedTeam")
  teamLevels        TeamLevel[]
  teamShifts        TeamShift[]
  scheduleRules     ScheduleRule[]

  @@unique([name])
  @@map("teams")
}

/** Nível configurável por equipe. É a fonte de verdade para o nível de um TeamMember. */
model TeamLevel {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  /** Nome exibido na UI. Único por equipe. */
  label     String
  /** Cor (hex) para destacar o nível na UI. */
  color     String   @default("#64748b")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team              Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  allowedShifts     TeamLevelAllowedShift[]
  members           TeamMember[]
  scheduleRules     ScheduleRule[]
  onCallAssignments OnCallAssignment[]

  @@unique([teamId, label])
  @@index([teamId])
  @@map("team_levels")
}

/** Turno configurável por equipe. É a fonte de verdade para o turno de um TeamMember. */
model TeamShift {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  label     String
  /** Cor (hex) para destacar o turno na UI. */
  color     String   @default("#64748b")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team             Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  allowedForLevels TeamLevelAllowedShift[]
  members          TeamMember[]
  scheduleRules    ScheduleRule[]

  @@unique([teamId, label])
  @@index([teamId])
  @@map("team_shifts")
}

/** Quais níveis podem trabalhar em quais turnos (por equipe). */
model TeamLevelAllowedShift {
  teamLevelId String @map("team_level_id")
  teamShiftId String @map("team_shift_id")

  teamLevel TeamLevel @relation(fields: [teamLevelId], references: [id], onDelete: Cascade)
  teamShift TeamShift @relation(fields: [teamShiftId], references: [id], onDelete: Cascade)

  @@id([teamLevelId, teamShiftId])
  @@index([teamShiftId])
  @@map("team_level_allowed_shifts")
}

model TeamMember {
  id                    String   @id @default(cuid())
  teamId          String?  @map("team_id")
  /** FK para TeamLevel: fonte de verdade do nível do membro. */
  teamLevelId     String   @map("team_level_id")
  /** FK para TeamShift: fonte de verdade do turno do membro. */
  teamShiftId     String   @map("team_shift_id")
  name            String
  phone           String
  normalizedPhone String   @map("normalized_phone")
  sobreaviso      Boolean  @default(false)
  participatesInSchedule Boolean @default(true) @map("participates_in_schedule")
  rotationIndex         Int      @default(0) @map("rotation_index")
  onCallRotationIndex   Int      @default(0) @map("on_call_rotation_index")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  scheduleAssignments     ScheduleAssignment[]
  swapRequestsAsRequester ScheduleSwapRequest[] @relation("SwapRequester")
  swapRequestsAsTarget    ScheduleSwapRequest[] @relation("SwapTarget")
  onCallAssignments       OnCallAssignment[]

  bankHourBalance       BankHourBalance? @relation("BankHourBalance")
  bankHourRequests      BankHourRequest[] @relation("BankHourRequests")
  bankHourTransactions   BankHourTransaction[] @relation("BankHourTransactions")

  team      Team?     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  teamLevel TeamLevel @relation(fields: [teamLevelId], references: [id], onDelete: Restrict)
  teamShift TeamShift @relation(fields: [teamShiftId], references: [id], onDelete: Restrict)

  @@index([teamId])
  @@index([teamLevelId])
  @@index([teamShiftId])
  @@index([normalizedPhone])
  @@map("team_members")
}

enum ScheduleStatus {
  OPEN
  LOCKED
}

enum AssignmentStatus {
  WORK
  OFF
  SWAP_REQUESTED
}

model Schedule {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  month     Int
  year      Int
  status    ScheduleStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ScheduleAssignment[]

  team Team @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@unique([teamId, year, month], map: "schedules_team_id_year_month_key")
  @@map("schedules")
}

model ScheduleAssignment {
  id         String           @id @default(cuid())
  scheduleId String           @map("schedule_id")
  memberId   String           @map("member_id")
  date       DateTime
  status     AssignmentStatus

  schedule Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  member   TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, memberId, date])
  @@map("schedule_assignments")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum SwapType {
  OFF_SWAP
  QUEUE_SWAP
  ONCALL_SWAP
  SHIFT_SWAP
}

enum SwapRequestStatus {
  PENDING
  WAITING_SECOND_USER
  SECOND_USER_ACCEPTED
  APPROVED
  REJECTED
  CANCELLED
}

model ScheduleSwapRequest {
  id                   String            @id @default(cuid())
  type                 SwapType
  requesterId          String            @map("requester_id")
  targetMemberId       String?           @map("target_member_id")
  originalDate         DateTime?         @map("original_date")
  targetDate           DateTime?         @map("target_date")
  justification        String?           @map("justification")
  status               SwapRequestStatus
  secondUserAcceptedAt DateTime?        @map("second_user_accepted_at")
  adminApprovedAt      DateTime?         @map("admin_approved_at")
  adminRejectedAt      DateTime?         @map("admin_rejected_at")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  requester   TeamMember @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetMember TeamMember? @relation("SwapTarget", fields: [targetMemberId], references: [id], onDelete: SetNull)

  @@map("schedule_swap_requests")
}

model OnCallAssignment {
  id          String   @id @default(cuid())
  memberId    String   @map("member_id")
  teamLevelId String?  @map("team_level_id")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")

  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  teamLevel TeamLevel? @relation(fields: [teamLevelId], references: [id], onDelete: SetNull)

  @@index([teamLevelId])
  @@map("on_call_assignments")
}

enum BankHourRequestType {
  EXTRA_HOURS
  OFF_HOURS
}

enum BankHourRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model BankHourBalance {
  memberId     String   @id @map("member_id")
  balanceHours Decimal  @default(0) @map("balance_hours") @db.Decimal(10, 2)
  updatedAt    DateTime @updatedAt @map("updated_at")

  member TeamMember @relation("BankHourBalance", fields: [memberId], references: [id], onDelete: Cascade)

  @@map("bank_hour_balances")
}

model BankHourRequest {
  id             String                  @id @default(cuid())
  type           BankHourRequestType
  requesterId    String                  @map("requester_id")
  date           DateTime                @map("date")
  hours          Decimal                 @map("hours") @db.Decimal(10, 2)
  justification  String?                 @map("justification")
  status         BankHourRequestStatus
  adminApprovedAt DateTime?             @map("admin_approved_at")
  adminRejectedAt DateTime?             @map("admin_rejected_at")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  requester TeamMember @relation("BankHourRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  transaction BankHourTransaction?

  @@index([requesterId, status])

  @@map("bank_hour_requests")
}

model BankHourTransaction {
  id          String            @id @default(cuid())
  memberId    String            @map("member_id")
  requestId   String            @unique @map("request_id")
  deltaHours  Decimal           @map("delta_hours") @db.Decimal(10, 2)
  createdAt   DateTime          @default(now()) @map("created_at")

  member   TeamMember     @relation("BankHourTransactions", fields: [memberId], references: [id], onDelete: Cascade)
  request  BankHourRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("bank_hour_transactions")
}

/**
 * Tipos de regra de escala reconhecidos pelo motor de geração.
 *
 * - WEEKEND_COVERAGE: quantas pessoas do escopo trabalham no fim de semana.
 *   params: { count: number }. count=0 significa que o grupo sempre folga no FDS
 *   (equivalente ao comportamento antigo de ESPC/PRODUCAO).
 *
 * - COMPENSATION_PATTERN: dias da semana usados para as folgas de compensação
 *   (uma na semana anterior e uma na posterior). params: { patterns: Array<{
 *   dayBefore: 1..5; dayAfter: 1..5 }> }. Para grupos com 2 pessoas, a 1ª usa
 *   patterns[0], a 2ª usa patterns[1]; se a lista tiver só 1, todas usam o mesmo.
 */
enum RuleKind {
  WEEKEND_COVERAGE
  COMPENSATION_PATTERN
}

/**
 * Regra de escala parametrizável. O escopo é determinado pela combinação
 * (teamId, teamShiftId?, teamLevelId?). Regra mais específica vence na
 * resolução; empate → maior `priority` → `updatedAt` mais recente.
 *
 * `params` é JSON validado por Zod no servidor; o shape depende de `kind`.
 */
model ScheduleRule {
  id          String   @id @default(cuid())
  teamId      String   @map("team_id")
  teamShiftId String?  @map("team_shift_id")
  teamLevelId String?  @map("team_level_id")
  kind        RuleKind
  enabled     Boolean  @default(true)
  priority    Int      @default(100)
  params      Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")

  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamShift TeamShift? @relation(fields: [teamShiftId], references: [id], onDelete: Cascade)
  teamLevel TeamLevel? @relation(fields: [teamLevelId], references: [id], onDelete: Cascade)

  @@index([teamId, kind, enabled])
  @@index([teamShiftId])
  @@index([teamLevelId])
  @@map("schedule_rules")
}
